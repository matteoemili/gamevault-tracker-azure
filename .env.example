# Azure Table Storage Configuration
# Copy this file to .env and fill in your values

# Your Azure Storage Account name
VITE_AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name

# Authentication Option 1: SAS Token (Recommended for client-side apps)
# Generate this from Azure Portal: Storage Account > Shared access signature
# Required permissions: Table (Read, Write, Add, Delete, List)
# Example: sv=2022-11-02&ss=t&srt=sco&sp=rwdlacu&se=2025-12-31T23:59:59Z&st=2025-01-01T00:00:00Z&spr=https&sig=...
VITE_AZURE_STORAGE_SAS_TOKEN=your-sas-token-here

# Authentication Option 2: Account Key (Use ONLY for testing or server-side)
# WARNING: Never expose account keys in client-side code in production!
# Find this in Azure Portal: Storage Account > Access keys
# VITE_AZURE_STORAGE_ACCOUNT_KEY=your-base64-encoded-account-key

# NOTE: You must provide either SAS_TOKEN or ACCOUNT_KEY (not both)
# For production client-side apps, always use SAS tokens with minimal permissions

# Optional: Custom Azure Storage endpoint (defaults to standard Azure endpoint)
# VITE_AZURE_STORAGE_ENDPOINT=https://your-storage-account.table.core.windows.net

# Optional: Custom table names (defaults shown)
# VITE_AZURE_GAMES_TABLE_NAME=games
# VITE_AZURE_CATEGORIES_TABLE_NAME=categories

# ============================================================================
# CI/CD NOTE: 
# In GitHub Actions, these values are automatically injected from the 
# infrastructure deployment job. No GitHub secrets are needed!
# ============================================================================
